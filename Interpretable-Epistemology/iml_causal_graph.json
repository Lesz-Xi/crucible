    "structural_equations": [
        {
            "node": "H_stat_membership",
            "equation": "H_stat_membership := 1 iff Complexity_f < epsilon and f in H_stat; else 0"
        },
        {
            "node": "H_ml_membership",
            "equation": "H_ml_membership := 1 iff Complexity_f >= epsilon and f is optimized for empirical risk; else 0"
        },
        {
            "node": "Interp_f",
            "equation": "Interp_f := 1 / (1 + Complexity_f) if no post-hoc operator applied; else Interp_f += alpha1*O_comp_applicable + alpha2*O_sens_reliable + alpha3*O_surr_fidelity"
        },
        {
            "node": "Delta_causal",
            "equation": "Delta_causal := |f_pred - f_cause|, where f_pred uses X_confound and f_cause excludes it"
        },
        {
            "node": "P_manifold",
            "equation": "P_manifold := P(x_prime) with P(x_prime) approx 0 if x_prime = perturb(x, i, j) and Cov(X_i, X_j) != 0"
        },
        {
            "node": "x_prime_extrapolated",
            "equation": "x_prime_extrapolated := 1 iff P_manifold < delta_manifold"
        },
        {
            "node": "f_decomposable",
            "equation": "f_decomposable := 1 iff f = sum_j(theta_j * phi_j(x_j)) or f is modular"
        },
        {
            "node": "O_comp_applicable",
            "equation": "O_comp_applicable := f_decomposable"
        },
        {
            "node": "O_sens_reliable",
            "equation": "O_sens_reliable := 1 iff P_manifold >= delta_manifold and x_prime_extrapolated = 0"
        },
        {
            "node": "O_surr_fidelity",
            "equation": "O_surr_fidelity := E_x[1 - L(g(x), f(x))] for x in Local_neighborhood and g in H_stat"
        },
        {
            "node": "sigma2_E",
            "equation": "sigma2_E := Var(E_hat); typically unknown for many post-hoc estimators"
        },
        {
            "node": "L_interp",
            "equation": "L_interp := Delta_causal + lambda * Complexity_f"
        }
    ],
    "constraints": [
        {
            "id": "intrinsic_interp",
            "expression": "if f in H_stat and Complexity_f < epsilon, then Interp_f > Interp_min > 0"
        },
        {
            "id": "decomposability",
            "expression": "O_comp applicable iff f = sum(theta_j * phi_j(x_j)) (additive) or f is modular"
        },
        {
            "id": "surrogate_fidelity",
            "expression": "g(x) approx f(x) for all x in Neigh(x_0), with g in H_stat"
        },
        {
            "id": "regime_separation",
            "expression": "lim (Complexity_f -> inf) H_stat intersection H_ml = empty"
        },
        {
            "id": "sensitivity_manifold_constraint",
            "expression": "O_sens valid only when perturbation support remains on manifold"
        },
        {
            "id": "uncertainty_gap",
            "expression": "sigma2_E is unknown for most IML estimators without resampling"
        }
    ],
    "interventions": [
        {
            "id": "do_reduce_complexity",
            "do": [
                "set Complexity_f < epsilon"
            ],
            "effect": "forces f into H_stat, increases Interp_f"
        },
        {
            "id": "do_remove_confounders",
            "do": [
                "remove X_confound from feature set"
            ],
            "effect": "reduces Delta_causal, aligns f_pred with f_cause"
        },
        {
            "id": "do_apply_operator",
            "do": [
                "apply O_comp or O_sens or O_surr to f"
            ],
            "effect": "increases Interp_f even if Complexity_f is high"
        },
        {
            "id": "do_enforce_manifold",
            "do": [
                "restrict perturbations to P_manifold > delta"
            ],
            "effect": "prevents extrapolation artifacts, ensures O_sens reliability"
        }
    ],
    "notes": [
        "Edges encode confounder-driven divergence and manifold-sensitive operator validity.",
        "No X_confound -> f_cause edge is included by design to preserve causal objective semantics."
    ]
}
