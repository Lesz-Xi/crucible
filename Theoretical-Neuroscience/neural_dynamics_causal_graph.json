  "structural_equations": [
    {
      "node": "V",
      "equation": "τ_m ∂V/∂t = λ² ∂²V/∂x² - V + r_m i_e",
      "description": "Passive cable equation from Kirchhoff's laws",
      "domain": "B"
    },
    {
      "node": "V",
      "equation": "τ_m ∂V/∂t = λ² ∂²V/∂x² - V - g_Na m³h(V - E_Na) - g_K n⁴(V - E_K)",
      "description": "Cable equation plus Hodgkin-Huxley active conductances",
      "domain": "B"
    },
    {
      "node": "firing_rate",
      "equation": "ν = 1 / (τ_ref + τ_m ln((V_rest - V_thresh + r_m i_e)/(V_reset - V_thresh + r_m i_e)))",
      "description": "f-I curve for leaky integrate-and-fire neuron",
      "domain": "B"
    },
    {
      "node": "v_E",
      "equation": "τ_E dv_E/dt = -v_E + F(W_EE v_E + W_EI v_I + I_E)",
      "description": "Wilson-Cowan excitatory population dynamics",
      "domain": "D"
    },
    {
      "node": "v_I",
      "equation": "τ_I dv_I/dt = -v_I + F(W_IE v_E + W_II v_I + I_I)",
      "description": "Wilson-Cowan inhibitory population dynamics",
      "domain": "D"
    },
    {
      "node": "network_state",
      "equation": "stable ⇔ Re(eigenvalue_M)<1; line_attractor ⇔ eigenvalue_M=1; unstable ⇔ Re(eigenvalue_M)>1",
      "description": "Deterministic stability classifier from recurrent eigen-spectrum",
      "domain": "D"
    },
    {
      "node": "E_boltzmann",
      "equation": "E = -h·v - (1/2) v·M·v",
      "description": "Boltzmann machine energy function",
      "domain": "D"
    },
    {
      "node": "r",
      "equation": "r(t) = ∫ K(τ) s(t-τ) dτ + noise",
      "description": "Linear encoding model from stimulus to response",
      "domain": "I"
    },
    {
      "node": "Fisher_I",
      "equation": "I(s) = ∫ (1/P(r|s)) (∂P(r|s)/∂s)^2 dr",
      "description": "Fisher information from response likelihood geometry",
      "domain": "I"
    },
    {
      "node": "var_s_hat",
      "equation": "var(s_hat) ≥ 1 / I(s)",
      "description": "Cramér-Rao lower bound",
      "domain": "I"
    },
    {
      "node": "w",
      "equation": "τ_w dw/dt = v u - α v² w",
      "description": "Oja learning rule",
      "domain": "L"
    },
    {
      "node": "delta_TD",
      "equation": "δ(t) = r(t) + v(t+1) - v(t)",
      "description": "Temporal-difference prediction error",
      "domain": "L"
    },
    {
      "node": "free_energy",
      "equation": "F = Σ_v P(v|u) ln P(u,v) + H(P(v|u))",
      "description": "EM variational free-energy lower bound",
      "domain": "L"
    },
    {
      "node": "L_neural",
