  "structural_equations": [
    {
      "node": "P_connection",
      "equation": "P(a_ij = 1) = kappa * exp(-eta * d_ij)",
      "description": "Distance-dependent connectivity with spatial decay constant eta"
    },
    {
      "node": "C_wire",
      "equation": "C_wire = sum_{i,j} a_ij * d_ij",
      "description": "Total axonal volume as sum of connection distances"
    },
    {
      "node": "E_glob",
      "equation": "E_glob = (1 / (N(N-1))) * sum_{i != j} (1 / L_ij)",
      "description": "Average inverse shortest path length, well-defined for disconnected graphs"
    },
    {
      "node": "H_evol",
      "equation": "max H_evol = alpha * E_glob - beta * C_wire",
      "description": "Fitness function balancing communication efficiency versus metabolic cost"
    },
    {
      "node": "sigma_small_world",
      "equation": "sigma = (C_actual / C_random) / (L_actual / L_random)",
      "description": "Small-world state satisfies sigma > 1 (high clustering and short paths)"
    },
    {
      "node": "F_ij",
      "equation": "F_ij = (<x_i(t)x_j(t)> - <x_i(t)><x_j(t)>) / (sigma_i * sigma_j)",
      "description": "Time-averaged Pearson correlation, coupled to structure via F_ij approximately f(a_ij)"
    },
    {
      "node": "P_k",
      "equation": "P(k) proportional to k^(-gamma) * exp(-k / k_c)",
      "description": "Degree distribution with exponential cutoff from spatial and metabolic constraints"
    },
    {
      "node": "Psi_patho",
      "equation": "Psi_patho = E_glob(G) - E_glob(G \\ {v in H_hubs})",
      "description": "Drop in global efficiency from hub deletion"
    }
  ],
  "constraints": [
    {
      "id": "distance_cost_coupling",
      "expression": "P(a_ij = 1) proportional to exp(-eta * d_ij), with eta > 0",
      "type": "biological_constraint"
    },
    {
      "id": "lattice_regime",
      "expression": "if beta -> infinity, topology_regime = lattice and C_wire -> min, E_glob -> 0",
      "type": "optimization_limit"
    },
    {
      "id": "random_regime",
      "expression": "if alpha -> infinity, topology_regime = random and E_glob -> max, C_wire -> max",
      "type": "optimization_limit"
    },
    {
      "id": "small_world_archetype",
      "expression": "for finite (alpha, beta), topology_regime = small-world with sigma > 1",
      "description": "Critical state balancing local clustering and short global paths",
      "type": "emergent_property"
    },
    {
      "id": "structure_function_coupling",
      "expression": "F_ij approximately f(a_ij) at low frequency; dF/dt != 0 while dA/dt approximately 0",
      "type": "dynamical_constraint"
    },
    {
      "id": "truncated_power_law",
      "expression": "P(k) has exponential cutoff k_c due to spatial volume and metabolic saturation",
      "description": "Prevents infinite-capacity hubs",
      "type": "physical_constraint"
    },
    {
      "id": "hub_vulnerability",
      "expression": "H_hubs = {v | k_v >> <k> and betweenness_v >> <betweenness>} and targeted hub removal collapses E_glob",
      "description": "Robust to random failures, vulnerable to targeted attacks",
      "type": "pathological_mechanism"
    }
  ],
  "interventions": [
    {
      "id": "do_minimize_wiring",
      "do": [
        "set beta -> infinity"
      ],
      "effect": "forces topology_regime to lattice, minimizes C_wire, reduces E_glob",
      "biological_analog": "developmental pressure for local connectivity"
    },
    {
      "id": "do_maximize_efficiency",
      "do": [
        "set alpha -> infinity"
      ],
      "effect": "forces topology_regime to random, maximizes E_glob, increases C_wire",
      "biological_analog": "evolutionary pressure for rapid communication"
    },
    {
      "id": "do_balance_small_world",
      "do": [
        "optimize alpha, beta to maximize H_evol"
      ],
      "effect": "topology_regime to small-world with sigma > 1",
      "biological_analog": "evolutionary optimization for brain architecture"
    },
    {
      "id": "do_random_attack",
      "do": [
        "set attack_type = random",
        "remove random nodes from V"
      ],
      "effect": "E_glob degrades gradually, dysconnectivity_syndrome remains false",
      "biological_analog": "normal aging and random neuronal death"
    },
    {
      "id": "do_targeted_attack",
      "do": [
        "set attack_type = targeted",
        "remove nodes in H_hubs"
      ],
      "effect": "Psi_patho increases sharply, E_glob collapses, dysconnectivity_syndrome becomes true",
      "biological_analog": "Alzheimer's and schizophrenia-like hub pathology"
    },
    {
      "id": "do_increase_decay",
      "do": [
        "increase eta"
      ],
      "effect": "reduces long-range P_connection, raises locality, and lowers C_wire",
      "biological_analog": "tightened metabolic constraints"
    }
  ]
}
